          "fetch_limit": 15,
          "min_score": 50
        }
      ],
      "users": [
        {
          "username": "iamthatis",
          "enabled": true,
          "sort": "new",
          "fetch_limit": 10
        }
      ],
      "fetch_comments": 5
    },
    "twitter": {
      "enabled": false,
      "users": ["karpathy", "ylecun"],
      "fetch_limit": 10,
      "fetch_reply_text": false,
      "max_replies_per_tweet": 3,
      "max_tweets_to_expand": 10,
      "reply_min_likes": 5
    },
    "openbb": {
      "enabled": false,
      "fetch_filings": false,
      "filings_provider": "sec",
      "watchlists": [
        {
          "name": "megacaps",
          "enabled": true,
          "provider": "yfinance",
          "fetch_limit": 20,
